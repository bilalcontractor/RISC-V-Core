# RISCOF configuration template.
# Copy this to config.ini and replace <REPO_ROOT> with the absolute path to
# your local HolyCore checkout, e.g. /home/you/Documents/SystemVerilog/HolyCore.
# config.ini itself is gitignored because these paths are machine-specific.

[RISCOF]
ReferencePlugin=sail_cSim
ReferencePluginPath=<REPO_ROOT>/sail_cSim
DUTPlugin=spike
DUTPluginPath=<REPO_ROOT>/spike

[spike]
pluginpath=<REPO_ROOT>/spike
ispec=<REPO_ROOT>/spike/spike_isa.yaml
pspec=<REPO_ROOT>/spike/spike_platform.yaml
target_run=1

[sail_cSim]
pluginpath=<REPO_ROOT>/sail_cSim
