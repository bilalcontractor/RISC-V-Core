# RISCOF configuration template.
# Copy this to config.ini and replace <REPO_ROOT> with the absolute path to
# your local HolyCore checkout, e.g. /home/you/Documents/SystemVerilog/HolyCore.
# config.ini itself is gitignored because these paths are machine-specific.

[RISCOF]
ReferencePlugin=sail_cSim
ReferencePluginPath=<REPO_ROOT>/riscof/sail_cSim
DUTPlugin=core
DUTPluginPath=<REPO_ROOT>/riscof/riscof_core

[core]
pluginpath=<REPO_ROOT>/riscof/riscof_core
ispec=<REPO_ROOT>/riscof/riscof_core/core_isa.yaml
pspec=<REPO_ROOT>/riscof/riscof_core/core_platform.yaml
target_run=1

# Spike kept around as an alternative DUT for sanity-checking the flow
# (set DUTPlugin=spike above to compare sail vs spike instead of your core).
[spike]
pluginpath=<REPO_ROOT>/riscof/spike
ispec=<REPO_ROOT>/riscof/spike/spike_isa.yaml
pspec=<REPO_ROOT>/riscof/spike/spike_platform.yaml
target_run=1

[sail_cSim]
pluginpath=<REPO_ROOT>/riscof/sail_cSim
